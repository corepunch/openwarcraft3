// animated_sprite.fdf
// SPRITE frames referencing anim_pulse.mdx which has two sequences: Stand and Birth.
// Covers: multi-sequence model references, sprite siblings with different models.
// References TestUI/Models/anim_pulse.mdx generated by mdxgen.
// No Warcraft III assets.

Frame "FRAME" "TestAnimRoot" {
    Width  0.6,
    Height 0.4,
    SetPoint TOPLEFT, "TestAnimRoot", TOPLEFT, 0.0, 0.0,

    // Animated sprite using the model with two sequences
    Frame "SPRITE" "TestAnimSprite" {
        Width  0.2,
        Height 0.2,
        SetPoint CENTER, "TestAnimRoot", CENTER, 0.0, 0.0,
        BackgroundArt "TestUI/Models/anim_pulse.mdx",
    }

    // Second animated sprite offset to the right
    Frame "SPRITE" "TestAnimSpriteB" {
        Width  0.15,
        Height 0.15,
        SetPoint LEFT, "TestAnimSprite", RIGHT, 0.01, 0.0,
        BackgroundArt "TestUI/Models/anim_pulse.mdx",
    }

    // Mixed: static quad next to animated pulse
    Frame "SPRITE" "TestMixedQuadSprite" {
        Width  0.12,
        Height 0.12,
        SetPoint RIGHT, "TestAnimSprite", LEFT, -0.01, 0.0,
        BackgroundArt "TestUI/Models/quad_sprite.mdx",
    }

    // Backdrop behind the animated sprites
    Frame "BACKDROP" "TestAnimBackdrop" {
        Width  0.4,
        Height 0.25,
        SetPoint CENTER, "TestAnimRoot", CENTER, 0.0, 0.0,
        BackdropBackground "TestUI/Textures/checker_8x8.blp",
        BackdropTileBackground,
    }

    // Label above the animated sprites
    Frame "TEXT" "TestAnimLabel" {
        Width  0.3,
        Height 0.03,
        SetPoint BOTTOM, "TestAnimSprite", TOP, 0.0, 0.005,
        Text "AnimPulse",
    }
}
