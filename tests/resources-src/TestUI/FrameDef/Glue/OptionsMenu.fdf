                EditTextFrame "GamePortEditBoxText",

                Frame "TEXT" "GamePortEditBoxText" {
                    SetAllPoints,
                }
            }
        }

        Frame "FRAME" "VideoPanel" {
        }

        Frame "FRAME" "SoundPanel" {
        }
    }
}
