// backdrop_variants.fdf
// Backdrop property coverage: tiled background, edge files, corner flags, insets.
// References only TestUI/Textures/* paths generated by blpgen.
// No Warcraft III assets.

// ---- Tiled background backdrop --------------------------------------------

Frame "BACKDROP" "TestBackdropTiled" {
    Width  0.3,
    Height 0.2,
    SetPoint TOPLEFT, "TestBackdropTiled", TOPLEFT, 0.01, -0.01,
    BackdropTileBackground,
    BackdropBackground "TestUI/Textures/checker_8x8.blp",
}

// ---- Backdrop with nine-slice edge files (all using generated textures) ---

Frame "BACKDROP" "TestBackdropNineSlice" {
    Width  0.3,
    Height 0.2,
    SetPoint TOPLEFT, "TestBackdropNineSlice", TOPLEFT, 0.01, -0.01,
    BackdropBackground   "TestUI/Textures/solid_white.blp",
    BackdropCornerFlags  "UL|UR|BL|BR",
    BackdropCornerFile   "TestUI/Textures/panel_border_32x32.blp",
    BackdropEdgeFile     "TestUI/Textures/panel_border_32x32.blp",
    BackdropEdgeSize     0.008,
    BackdropLeftFile     "TestUI/Textures/panel_border_32x32.blp",
    BackdropRightFile    "TestUI/Textures/panel_border_32x32.blp",
    BackdropTopFile      "TestUI/Textures/panel_border_32x32.blp",
    BackdropBottomFile   "TestUI/Textures/panel_border_32x32.blp",
}

// ---- Backdrop with background insets (tests BackdropBackgroundInsets) ------

Frame "BACKDROP" "TestBackdropInsets" {
    Width  0.25,
    Height 0.15,
    SetPoint CENTER, "TestBackdropInsets", CENTER, 0.0, 0.0,
    BackdropBackground         "TestUI/Textures/checker_8x8.blp",
    BackdropBackgroundInsets   0.01, 0.01, 0.01, 0.01,
}

// ---- Alpha-blended backdrop (uses alpha_ring texture) ----------------------

Frame "BACKDROP" "TestBackdropAlpha" {
    Width  0.2,
    Height 0.2,
    SetPoint CENTER, "TestBackdropAlpha", CENTER, 0.0, 0.0,
    BackdropBackground "TestUI/Textures/alpha_ring_16x16.blp",
    BackdropBlendAll,
}

// ---- Mirrored backdrop -----------------------------------------------------

Frame "BACKDROP" "TestBackdropMirrored" {
    Width  0.25,
    Height 0.1,
    SetPoint BOTTOMRIGHT, "TestBackdropMirrored", BOTTOMRIGHT, -0.01, 0.01,
    BackdropBackground "TestUI/Textures/panel_border_32x32.blp",
    BackdropMirrored,
}

// ---- Child backdrop inside a container (parent-relative positioning) -------

Frame "FRAME" "TestBackdropContainer" {
    Width  0.5,
    Height 0.3,
    SetPoint TOPLEFT, "TestBackdropContainer", TOPLEFT, 0.0, 0.0,

    Frame "BACKDROP" "TestBackdropInContainer" {
        SetAllPoints,
        BackdropBackground "TestUI/Textures/solid_white.blp",
    }
}
