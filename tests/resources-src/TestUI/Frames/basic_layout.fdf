// basic_layout.fdf
// Pure anchor/layout coverage: FRAME, BACKDROP, and TEXT frames.
// References only TestUI/Textures/solid_white.blp which is generated by blpgen.
// No Warcraft III assets.

// ---- Root container -------------------------------------------------------

Frame "FRAME" "TestRootFrame" {
    SetPoint TOPLEFT,     "TestRootFrame", TOPLEFT,     0.0,  0.0,
    SetPoint BOTTOMRIGHT, "TestRootFrame", BOTTOMRIGHT, 0.0,  0.0,

    // Explicit-size child anchored to top-left
    Frame "FRAME" "TestTopLeftChild" {
        Width  0.2,
        Height 0.1,
        SetPoint TOPLEFT, "TestRootFrame", TOPLEFT, 0.01, -0.01,
    }

    // Explicit-size child anchored to top-right
    Frame "FRAME" "TestTopRightChild" {
        Width  0.2,
        Height 0.1,
        SetPoint TOPRIGHT, "TestRootFrame", TOPRIGHT, -0.01, -0.01,
    }

    // Centered child with explicit size
    Frame "FRAME" "TestCenterChild" {
        Width  0.3,
        Height 0.15,
        SetPoint CENTER, "TestRootFrame", CENTER, 0.0, 0.0,
    }

    // Bottom-aligned child
    Frame "FRAME" "TestBottomChild" {
        Width  0.4,
        Height 0.05,
        SetPoint BOTTOM, "TestRootFrame", BOTTOM, 0.0, 0.01,
    }

    // Dual-anchor stretch (fills a horizontal strip at the top)
    Frame "FRAME" "TestTopStretch" {
        Height 0.04,
        SetPoint TOPLEFT,  "TestRootFrame", TOPLEFT,  0.0, 0.0,
        SetPoint TOPRIGHT, "TestRootFrame", TOPRIGHT, 0.0, 0.0,
    }

    // Inset child relative to TestTopLeftChild (parent-relative offset)
    Frame "FRAME" "TestInsetChild" {
        Width  0.08,
        Height 0.04,
        SetPoint TOPLEFT, "TestTopLeftChild", TOPLEFT, 0.005, -0.005,
    }

    // Backdrop with solid-white texture
    Frame "BACKDROP" "TestBackdropBasic" {
        Width  0.15,
        Height 0.08,
        SetPoint CENTER, "TestRootFrame", CENTER, 0.0, -0.05,
        BackdropBackground "TestUI/Textures/solid_white.blp",
    }

    // Static text label
    Frame "TEXT" "TestLabel" {
        Width  0.2,
        Height 0.03,
        SetPoint TOPLEFT, "TestRootFrame", TOPLEFT, 0.02, -0.02,
        Text "TestLabel",
    }
}
