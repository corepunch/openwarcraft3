// simple_sprite.fdf
// SPRITE frame referencing a generated MDX model.
// Covers: BackgroundArt (model path), SetPoint, Width/Height on sprite frames.
// References TestUI/Models/quad_sprite.mdx generated by mdxgen.
// No Warcraft III assets.

Frame "FRAME" "TestSpriteRoot" {
    Width  0.4,
    Height 0.3,
    SetPoint TOPLEFT, "TestSpriteRoot", TOPLEFT, 0.0, 0.0,

    // Basic sprite referencing the generated quad model
    Frame "SPRITE" "TestQuadSprite" {
        Width  0.15,
        Height 0.15,
        SetPoint CENTER, "TestSpriteRoot", CENTER, 0.0, 0.0,
        BackgroundArt "TestUI/Models/quad_sprite.mdx",
    }

    // Sprite anchored to top-left corner
    Frame "SPRITE" "TestSpriteTopLeft" {
        Width  0.08,
        Height 0.08,
        SetPoint TOPLEFT, "TestSpriteRoot", TOPLEFT, 0.01, -0.01,
        BackgroundArt "TestUI/Models/quad_sprite.mdx",
    }

    // Sprite anchored to bottom-right corner
    Frame "SPRITE" "TestSpriteBottomRight" {
        Width  0.08,
        Height 0.08,
        SetPoint BOTTOMRIGHT, "TestSpriteRoot", BOTTOMRIGHT, -0.01, 0.01,
        BackgroundArt "TestUI/Models/panel_sprite.mdx",
    }

    // Sprite with explicit offset from sibling
    Frame "SPRITE" "TestSpriteRelative" {
        Width  0.08,
        Height 0.08,
        SetPoint TOPLEFT, "TestSpriteTopLeft", BOTTOMLEFT, 0.0, -0.01,
        BackgroundArt "TestUI/Models/quad_sprite.mdx",
    }
}
